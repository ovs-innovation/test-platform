# Copy to .env before running:  copy .env.example .env   (Windows)  |  cp .env.example .env  (macOS/Linux)
# Used by docker compose. Safe defaults are provided for local development.

# ----- PostgreSQL -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=interview_platform

# ----- Backend -----
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=2h
CLIENT_URL=http://localhost:5173

# Set to false after the first run if you do not want demo data re-seeded on restart.
RUN_SEED=true
SEED_ADMIN_EMAIL=admin@assess.io
SEED_ADMIN_PASSWORD=Admin@12345
SEED_CANDIDATE_EMAIL=candidate@assess.io
SEED_CANDIDATE_PASSWORD=Candidate@123

# ----- Ports (host) -----
FRONTEND_PORT=5173
BACKEND_PORT=5000
