{
  "name": "interview-assessment-backend",
  "version": "1.0.0",
  "description": "Production-grade Interview Assessment Platform API (Express + PostgreSQL + JWT)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node scripts/free-port.js && node --watch src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "db:reset": "node src/db/migrate.js --reset && node src/db/seed.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.10",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "razorpay": "^2.9.6",
    "zod": "^3.23.8"
  }
}
