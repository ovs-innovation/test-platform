# Server
PORT=5000
NODE_ENV=development
# Comma-separated allowed browser origins (no trailing slash)
CLIENT_URL=https://your-app.vercel.app,http://localhost:5173
INVITE_BASE_URL=https://your-app.vercel.app

# Database (use DATABASE_URL for Neon/production, or individual PG vars)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=interview_platform

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=2h

# Seed credentials (development only)
SEED_ADMIN_EMAIL=admin@assess.io
SEED_ADMIN_PASSWORD=Admin@12345

# Email (Gmail SMTP — app password must be 16 chars, no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=AssessPro <noreply@assesspro.io>

# OTP
OTP_EXPIRES_MINUTES=10
OTP_RESEND_LIMIT=3

# Razorpay (leave empty for dev mock payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
